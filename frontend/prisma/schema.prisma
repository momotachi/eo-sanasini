// EO Sanasini — Event Engine Schema
// General engine, specific configuration. Lihat docs/PRD.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ORGANIZATION & EVENTS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  tagline   String?
  about     String?  @db.Text
  logoUrl   String?
  website   String?
  instagram String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
}

// Kategori event — menentukan modul & field yang relevan
enum EventCategory {
  SPORT     // kejuaraan/liga olahraga
  FESTIVAL  // festival, pameran, bazaar
  MICE      // konferensi, seminar, workshop
  OTHER     // travel, gathering, dll
}

enum EventType {
  CHAMPIONSHIP
  LEAGUE
  FESTIVAL
  MICE
  OTHER
}

enum EventStatus {
  DRAFT
  REGISTRATION_OPEN
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Event {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  type         EventType
  category     EventCategory @default(SPORT)
  modules      Json?         // { registration, schedule, gallery, certificate, livestream, merch }
  status       EventStatus   @default(DRAFT)
  description  String?       @db.Text
  posterUrl    String?
  startDate    DateTime
  endDate      DateTime
  venue        String?
  address      String?
  mapUrl       String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  isPublic     Boolean       @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  config      EventConfig?
  contingents Contingent[]
  divisions   Division[]
  venues      Venue[]
  schedule    ScheduleItem[]
  medals      Medal[]
  participants Participant[]
  // multi-category relations
  staff       EventStaff[]
  tenants     Tenant[]
  stagePrograms StageProgram[]
  speakers    Speaker[]
  sessions    Session[]
  ticketTypes TicketType[]
  itinerary   ItineraryItem[]
  gallery     Gallery[]
  certificates Certificate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([category])
}

// ============================================================
// EVENT CONFIGURATION (template per event)
// ============================================================

enum CompetitionFormat {
  FULL_KNOCKOUT
  GROUP_KNOCKOUT
  ROUND_ROBIN
  SCORING
  NON_COMPETITIVE
}

enum RegistrationType {
  INDIVIDUAL
  TEAM
  HYBRID
}

model EventConfig {
  id                String           @id @default(cuid())
  eventId           String           @unique
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationType  RegistrationType @default(HYBRID)
  bronzePerDivision Int              @default(2)
  ageCategories     Json?
  disciplines       Json?
  extraConfig       Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ============================================================
// CONTINGENT (kontingen: perguruan/provinsi/negara)
// ============================================================

enum ContingentType {
  CLUB
  PROVINCE
  COUNTRY
  OTHER
}

model Contingent {
  id           String         @id @default(cuid())
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  type         ContingentType @default(CLUB)
  logoUrl      String?
  contactName  String?
  contactPhone String?
  participants Participant[]
  medals       Medal[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([eventId, name])
  @@index([eventId])
}

// ============================================================
// DIVISION (pool/class: kategori x gender x kelas x cabang)
// ============================================================

enum Gender {
  PUTRA
  PUTRI
  MIXED
}

model Division {
  id            String             @id @default(cuid())
  eventId       String
  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  discipline    String
  ageCategory   String
  gender        Gender
  className     String
  format        CompetitionFormat  @default(GROUP_KNOCKOUT)
  scoringConfig Json?
  participants  Participant[]
  matches       Match[]
  medals        Medal[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([eventId, discipline, ageCategory, gender, className])
  @@index([eventId])
}

// ============================================================
// PARTICIPANT
// ============================================================

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model Participant {
  id           String            @id @default(cuid())
  // generalisasi: peserta bisa atlet (sport), pengunjung (festival),
  // attendee (MICE), atau peserta trip (travel)
  eventId      String
  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  divisionId   String?           // nullable — wajib hanya untuk sport
  division     Division?         @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  contingentId String?
  contingent   Contingent?       @relation(fields: [contingentId], references: [id])
  ticketTypeId String?           // untuk MICE (tipe tiket)
  // data umum
  name         String
  gender       Gender            @default(PUTRA)
  birthDate    DateTime?
  email        String?
  phone        String?
  jobTitle     String?           // untuk MICE (jabatan/instansi)
  idDocNumber  String?           // untuk travel (KTP/passport)
  emergencyContact String?       // untuk travel
  documentUrl  String?
  seed         Int?
  status       ParticipantStatus @default(PENDING)
  meta         Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  matchesA      Match[]     @relation("MatchParticipantA")
  matchesB      Match[]     @relation("MatchParticipantB")
  winnerMatches Match[]     @relation("MatchWinner")
  medals        Medal[]
  ticketType    TicketType? @relation(fields: [ticketTypeId], references: [id])
  certificates  Certificate[]

  @@index([eventId])
  @@index([divisionId])
  @@index([contingentId])
  @@index([ticketTypeId])
}

// ============================================================
// MATCH (pertandingan)
// ============================================================

enum MatchStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  BYE
}

enum MatchRound {
  GROUP_STAGE
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  FINAL
  THIRD_PLACE
}

model Match {
  id              String       @id @default(cuid())
  divisionId      String
  division        Division     @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  round           MatchRound
  bracketPosition Int
  groupLabel      String?
  participantAId  String?
  participantA    Participant? @relation("MatchParticipantA", fields: [participantAId], references: [id])
  participantBId  String?
  participantB    Participant? @relation("MatchParticipantB", fields: [participantBId], references: [id])
  scoreA          Json?
  scoreB          Json?
  winnerId        String?
  winner          Participant? @relation("MatchWinner", fields: [winnerId], references: [id])
  status          MatchStatus  @default(SCHEDULED)
  venueId         String?
  venue           Venue?       @relation(fields: [venueId], references: [id])
  scheduledAt     DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([divisionId])
  @@index([status])
}

// ============================================================
// MEDAL (persist untuk klasemen cepat)
// ============================================================

enum MedalType {
  GOLD
  SILVER
  BRONZE
}

model Medal {
  id            String      @id @default(cuid())
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id])
  divisionId    String
  division      Division    @relation(fields: [divisionId], references: [id])
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])
  contingentId  String?
  contingent    Contingent? @relation(fields: [contingentId], references: [id])
  type          MedalType
  discipline    String
  createdAt     DateTime    @default(now())

  @@unique([divisionId, participantId, type])
  @@index([eventId])
  @@index([contingentId])
}

// ============================================================
// VENUE & SCHEDULE
// ============================================================

model Venue {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  area      String?
  matches   Match[]
  createdAt DateTime @default(now())

  @@unique([eventId, name])
}

model ScheduleItem {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time      DateTime
  title     String
  venueId   String?
  division  String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([eventId])
}

// ============================================================
// AUTH & RBAC (Role-Based Access Control)
// ============================================================

enum GlobalRole {
  SUPER_ADMIN  // programmer — akses penuh + user/role/system management
  ADMIN        // EO Sanasini — manage semua event, assign staf
  STAF         // panitia — manage hanya event yang di-assign
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  passwordHash  String
  role          GlobalRole @default(STAF)
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  eventAssignments EventStaff[]
}

// Junction STAF ↔ Event (untuk scoping akses staf)
model EventStaff {
  id        String     @id @default(cuid())
  userId    String
  eventId   String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([eventId])
}

// ============================================================
// FESTIVAL MODULE
// ============================================================

model Tenant {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  category     String?  // "Kuliner", "UMKM", "Fashion", "Teknologi"
  description  String?  @db.Text
  logoUrl      String?
  contactName  String?
  contactPhone String?
  boothNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
}

model StageProgram {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time        DateTime
  title       String
  performer   String?
  stage       String?  // "Panggung Utama", "Panggung Akustik"
  description String?
  createdAt   DateTime @default(now())

  @@index([eventId])
}

// ============================================================
// MICE MODULE
// ============================================================

model Speaker {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  title     String?  // "CEO PT X", "Prof. Dr."
  bio       String?  @db.Text
  photoUrl  String?
  email     String?
  sessions  Session[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
}

model Session {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  room        String?
  speakerId   String?
  speaker     Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  track       String?  // "Track A", "Workshop", "Keynote"
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
  @@index([speakerId])
}

model TicketType {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String    // "Early Bird", "Regular", "VIP"
  price       Decimal   @db.Decimal(12, 2)
  currency    String    @default("IDR")
  quota       Int?
  soldCount   Int       @default(0)
  description String?
  saleStart   DateTime?
  saleEnd     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participants Participant[]

  @@index([eventId])
}

// ============================================================
// TRAVEL/GATHERING MODULE
// ============================================================

model ItineraryItem {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  day          Int      // hari ke-1, ke-2
  time         DateTime
  title        String
  location     String?
  notes        String?
  transportMode String? // "Bus", "Pesawat", "Jalan kaki"
  createdAt    DateTime @default(now())

  @@index([eventId])
}

// ============================================================
// CROSS-CATEGORY MODULES (optional, toggle via event.modules)
// ============================================================

model Gallery {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  uploadedAt DateTime @default(now())

  @@index([eventId])
}

model Certificate {
  id            String      @id @default(cuid())
  eventId       String
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  templateUrl   String?
  issuedAt      DateTime?
  code          String      @unique // untuk verifikasi publik
  createdAt     DateTime    @default(now())

  @@index([eventId])
  @@index([participantId])
}
